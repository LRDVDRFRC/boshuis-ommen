{
  "version": 2,
  "name": "boshuis-ommen",
  "buildCommand": null,
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/email-templates",
      "dest": "/email-templates.html"
    },
    {
      "src": "/backend-setup-guide",
      "dest": "/backend-setup-guide.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
